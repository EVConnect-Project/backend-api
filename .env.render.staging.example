NODE_ENV=production

# Core
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=replace-with-second-strong-secret
JWT_REFRESH_EXPIRES_IN=7d

# Frontend origins (comma-separated)
ALLOWED_ORIGINS=https://web-staging.example.com,https://admin-staging.example.com

# Trip planner / AI service
AI_SERVICE_URL=https://ai-staging.example.com
GOOGLE_MAPS_API_KEY=
MAPBOX_API_KEY=

# Payments (PayHere sandbox)
PAYHERE_BASE_URL=https://sandbox.payhere.lk
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_NOTIFY_URL=https://api-staging.example.com/api/payments/webhook
PAYHERE_RETURN_URL=https://web-staging.example.com/payment/success
PAYHERE_CANCEL_URL=https://web-staging.example.com/payment/cancel
PAYHERE_CARD_SETUP_URL=
MOBILE_CARD_SETUP_CALLBACK_URL=evrs://wallet/card-setup

# SMS (Text.lk)
TEXTLK_API_TOKEN=
TEXTLK_SENDER_ID=EVRS
TEXTLK_OAUTH_API_ENDPOINT=https://app.text.lk/api/v3/
TEXTLK_HTTP_API_ENDPOINT=https://app.text.lk/api/http/
SMS_APP_NAME=EVRS

# Firebase push
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Cloudinary uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=