{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true
  },
  "exclude": [
    "admin-dashboard/**",
    "mobile-app/**",
    "ai-services/**",
    "infra/**",
    "design/**",
    "docs/**",
    "node_modules/**",
    "dist/**"
  ]
}
