# AI Services Environment Configuration
# Copy this file to .env and update with your values

# Server
AI_HOST=0.0.0.0
AI_PORT=5000

# Model Configuration
AI_MODEL_PATH=./models/route_optimizer.pkl
MODEL_TYPE=random_forest
MODEL_VERSION=1.0.0

# Database (if needed for AI service)
DATABASE_URL=postgresql://evconnect:evconnect_pass@postgres:5432/evconnect

# Redis Cache (for ML predictions caching)
REDIS_URL=redis://redis:6379

# ML Configuration
MAX_PREDICTIONS_PER_REQUEST=100
PREDICTION_TIMEOUT=30
CACHE_PREDICTIONS=true
CACHE_TTL=3600

# Logging
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# API Keys (if using external services)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
WEATHER_API_KEY=your_weather_api_key
