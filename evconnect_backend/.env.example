# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=evconnect
DATABASE_PASSWORD=your_secure_password_here
DATABASE_NAME=evconnect

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long
JWT_REFRESH_SECRET=your_refresh_secret_key_minimum_32_characters_long
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# Server Configuration
PORT=3000
NODE_ENV=development

# Charging Service Integration
CHARGING_SERVICE_URL=http://localhost:4000
CHARGING_SERVICE_API_KEY=evconnect-backend-api-key-dev

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# CORS Origins (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:8080,http://localhost:5173

# Redis (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# Logging
LOG_LEVEL=debug
