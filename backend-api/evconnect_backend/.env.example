# Backend Environment Configuration
# Copy this file to .env and update with your values

# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://evconnect:evconnect_pass@postgres:5432/evconnect
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=evconnect
DB_PASSWORD=evconnect_pass
DB_DATABASE=evconnect

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_REFRESH_EXPIRATION=30d

# Redis Cache
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@evconnect.com

# API Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# WebSocket
WEBSOCKET_CORS_ORIGIN=http://localhost:8080,http://localhost:3000
